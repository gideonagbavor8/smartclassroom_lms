{
  "name": "learnmate-ghana",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "db:generate": "npm run generate -w @learnmate/db",
    "db:migrate": "npm run migrate -w @learnmate/db",
    "db:push": "npm run push -w @learnmate/db"
  }
}
